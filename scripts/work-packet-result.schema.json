{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "status": {
      "type": "string",
      "enum": ["completed", "needs_changes", "blocked"]
    },
    "summary": {
      "type": "string"
    },
    "verification": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": ["status", "summary", "verification", "issues"],
  "additionalProperties": false
}
