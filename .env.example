APP_ENV=development
APP_BASE_URL=http://localhost:3000
DATABASE_URL=postgresql+psycopg://orchestrator:orchestrator-local@postgres:5432/orchestrator
MODEL_PROVIDER=lm-studio
LM_STUDIO_BASE_URL=http://127.0.0.1:1234/v1
LM_STUDIO_API_KEY=lm-studio
LM_STUDIO_MODEL_ID=qwen3.6-27b
LM_STUDIO_RELAY_UPSTREAM_PORT=1234
PROJECT_ROOTS=/projects
PROJECT_PATH_HOST=./projects/example
PROJECT_NAME=example
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_CONTENT_CAPTURE=false
ARTIFACT_ROOT=/var/lib/orchestrator/artifacts
PI_VM_ROOT=/var/lib/orchestrator/vms
PI_VM_BASE_IMAGE=/var/lib/orchestrator/base/pi-base.qcow2
PI_VM_MEMORY_MB=4096
PI_VM_CPU_COUNT=4
PI_VM_OPERATION_TIMEOUT_SECONDS=30
PI_VM_SSH_PRIVATE_KEY=/var/lib/orchestrator/ssh/id_ed25519
PI_VM_SSH_KNOWN_HOSTS=/var/lib/orchestrator/ssh/known_hosts
PI_GUEST_BINARY=pi
PI_GUEST_PROVIDER=lm-studio
PI_GUEST_MODEL=qwen3.6-27b
PI_GUEST_ATTEMPT_TIMEOUT_SECONDS=300
PI_GUEST_CLIENT_TIMEOUT_SECONDS=330
PI_GUEST_READY_TIMEOUT_SECONDS=45
PI_PREVIEW_PORTS=3000,4173,5173,8000,8080
RUNNER_LEASE_SECONDS=600
RUNNER_OWNER=runner-compose-1
VM_MANAGER_URL=http://vm-manager:8010
VM_MANAGER_AUTH_TOKEN=replace-with-at-least-24-random-characters
DESKTOP_SESSION_SECRET=replace-with-at-least-32-random-characters
EGRESS_AUTH_SECRET=replace-with-at-least-32-random-characters
EGRESS_PUBLIC_HOSTS=example.com,www.example.com
EGRESS_CONNECTION_BUDGET_BYTES=52428800
EGRESS_RUN_BUDGET_BYTES=209715200
EGRESS_TIMEOUT_SECONDS=120
PROMOTION_MANAGER_AUTH_TOKEN=replace-with-at-least-24-random-characters
PROMOTION_CONFIRMATION_SECRET=replace-with-at-least-32-random-characters
HOST_UID=1000
HOST_GID=1000
KVM_GID=108
RESULT_ROOT=/var/lib/orchestrator/results
GUEST_WORKSPACE_ROOT=/home/piagent/workspaces
GUEST_EGRESS_MODE=web-proxy
DESKTOP_SESSION_TTL_SECONDS=900
PROMOTION_BRANCH_PREFIX=orchestrator/
